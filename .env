# Supabase project settings (Settings -> API in the Supabase dashboard).
# These values are public by design — they ship in the JS bundle either way.
# Row Level Security is the actual security boundary. Never put the
# service-role key here or anywhere else in this repo.
VITE_SUPABASE_URL=https://YOUR-PROJECT-REF.supabase.co
VITE_SUPABASE_ANON_KEY=YOUR-ANON-KEY
